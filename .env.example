# ─── Django ──────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-secreta-forte
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Banco de dados (PostgreSQL) ─────────────────
DB_NAME=ged_veiculos
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_HOST=localhost
DB_PORT=5432

# ─── Microsoft Graph / OneDrive ──────────────────
# Crie um App Registration no portal.azure.com:
#   1. Azure Active Directory → App registrations → New registration
#   2. Certificates & secrets → New client secret
#   3. API permissions → Microsoft Graph → Application → Files.ReadWrite.All → Grant admin consent
#
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=seu_client_secret_aqui
MICROSOFT_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ID do SharePoint Drive compartilhado (opcional - deixe vazio para usar o OneDrive pessoal do app)
# Para obter: GET https://graph.microsoft.com/v1.0/sites/{siteId}/drives
MICROSOFT_DRIVE_ID=

# Nome da pasta raiz no OneDrive
ONEDRIVE_ROOT_FOLDER=GED_Veiculos
